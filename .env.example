# Krishi Cure AI - Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# AI Service API Keys
# At least one of these is required for the application to work
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
# These are used for client-side authentication
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Example values for Firebase (update with your actual project details)
# FIREBASE_API_KEY=AIzaSyDXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# FIREBASE_AUTH_DOMAIN=krishi-cure-ai.firebaseapp.com
# FIREBASE_PROJECT_ID=krishi-cure-ai
# FIREBASE_STORAGE_BUCKET=krishi-cure-ai.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=123456789
# FIREBASE_APP_ID=1:123456789:web:abcdef123456
